<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<configSections>
		<section name="entityFramework"
            type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
            requirePermission="false" />
	</configSections>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>
	<connectionStrings>
		
		<!-- MongoDB connection string for user authentication -->
		<add name="MongoDBConnection"
             connectionString="mongodb://localhost:27017/HospitalDB"
             providerName="MongoDB" />
		
		<!-- SQL Server connection string for patient data, appointments, and inventory -->
		<!-- Each team member needs to update YOUR_SERVER_NAME to match their machine -->
		<add name="SQLConnection"
             connectionString="Data Source=YOUR_SERVER_NAME\SQLEXPRESS;Initial Catalog=HospitalDB;Integrated Security=True;TrustServerCertificate=True"
             providerName="System.Data.SqlClient" />
		
		<!-- SignalR hub URL for real time communication -->
		<add name="SignalRConnection"
             connectionString="http://localhost:8080/"
             providerName="SignalR" />
		
	</connectionStrings>
	<entityFramework>
		<defaultConnectionFactory
            type="System.Data.Entity.Infrastructure.LocalDbConnectionFactory, EntityFramework">
			<parameters>
				<parameter value="mssqllocaldb" />
			</parameters>
		</defaultConnectionFactory>
		<providers>
			<provider invariantName="System.Data.SqlClient"
                type="System.Data.Entity.SqlServer.SqlProviderServices, EntityFramework.SqlServer" />
		</providers>
	</entityFramework>
</configuration>